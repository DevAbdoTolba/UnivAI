# ---- LLM with automatic failover (provider:model syntax) ----
# providers: gemini | openai | ollama
LLM_PRIMARY=gemini:gemini-2.5-flash
LLM_FALLBACK=ollama:gemma3:4b
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ---- LiveKit — LOCAL docker server (starts with `make up`) ----
# devkey/secret are the livekit-server --dev built-ins; fine on localhost.
# 127.0.0.1, NOT localhost: the Rust rtc client tries ::1 first and can time
# out before falling back to IPv4 when a VPN/firewall drops IPv6 loopback.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# same URL, exposed to the browser
NEXT_PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880
# ---- LiveKit Cloud (free tier) — swap the four values above for a remote demo ----
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# ---- RAG (the team's EXISTING service: github.com/AhmeedFatehy/UnivAI-Agent) ----
# Their MCP server speaks streamable-http. Start it with:  uv run python mcp_server.py
RAG_MCP_URL=http://localhost:8000/mcp
RAG_USER_ID=student
RAG_TOOL_SEARCH=retrieve_context
RAG_TOOL_INGEST=ingest_file
# Their retrieval never returns empty (a vector search always yields neighbours).
# Drop hits below this reranked score; the LLM still has to refuse off-book questions.
RAG_MIN_SCORE=0

# ---- Exams (UnivAI-exam_system submodule, port 3200) ----
MONGODB_URI=mongodb://localhost:27017/univai_exams
EXAM_SYSTEM_URL=http://localhost:3200
STUDENT_NAME=Mohamed Hany

# ---- Data ----
DATABASE_URL=postgresql://univai:univai@localhost:5433/univai

# ---- Voice (all local) ----
# Where the voice models run. auto = GPU if there is one, else CPU.
DEVICE=auto
STT_COMPUTE_TYPE=float16   # GPU: float16 | CPU: int8
TTS_ENGINE=piper           # piper (11x realtime) | coqui (XTTS: better voice, but 0.55x - too slow to lecture live)
PIPER_MODEL=models/piper/en_US-lessac-medium.onnx
COQUI_TOS_AGREED=1
STT_ENGINE=faster-whisper
STT_MODEL_SIZE=base        # base | small

# ---- Paths ----
LECTURES_DIR=./lectures
UPLOADS_DIR=./uploads
