# secrets — never commit
.env

# python
.venv/
__pycache__/
*.pyc

# node
node_modules/
.next/
out/
next-env.d.ts

# uploaded books (user data)
uploads/

# lecture content is generated from the uploaded book (services/lecture_gen.py)
# and committed so the team can see the current course in git (see lectures/)

# the lecturer's pre-rendered voice (services/prerender_audio.py) — binary,
# regenerable from script.json in minutes
lectures/*/audio/
lectures/_prompts/

# all service + build logs live here (see docs/running.md)
logs/
# log strays at the repo root
/*.log
/*.err

# caches (voice models live in UnivAI-live/models/, ignored by that repo)
.cache/

# os
Thumbs.db
.DS_Store

# generated by scripts/build-slides.mjs (run: make slides)
app/public/slides/
